{
  "expo": {
    "name": "CareerLens AI",
    "slug": "resume-screener",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "resumeapp",
    "splash": {
      "image": "./assets/splashscreen_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.deepith.careerlens"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D94E28"
      },
      "package": "com.deepith.careerlens",
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-font",
      "expo-document-picker",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "d4e232da-ee14-4ac7-8db4-f3c7dd19a18a"
      }
    },
    "owner": "deepu_1718"
  }
}